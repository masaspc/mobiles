---
import { getCollection } from 'astro:content';
import SiteShell from '../../components/SiteShell.astro';
import ModelActions from '../../components/ModelActions';
import { deriveModel } from '../../data/schema';
import { withBase } from '../../lib/url';

export async function getStaticPaths() { const all=await getCollection('models'); return all.map(entry=>({params:{id:entry.data.id},props:{model:deriveModel(entry.data)}})); }
const { model } = Astro.props;
const dash = (value: unknown) => value === null || value === undefined || value === '' ? '—' : String(value);
const yesNo = (value: boolean | null | undefined) => value === null || value === undefined ? '—' : value ? '対応' : '—';
const resolution = model.display.resolution ? `${model.display.resolution.width} × ${model.display.resolution.height}` : null;
const groups = [
  { key:'performance', icon:'⚙', title:'性能', items:[['CPU',`${model.cpu.vendor} ${model.cpu.model}`],['アーキテクチャ',model.cpu.isa],['Geekbench 6 Multi',model.performanceScore],['NPU',model.cpu.npuTops === null || model.cpu.npuTops === undefined ? null : `${model.cpu.npuTops} TOPS`],['メモリ',`${model.memory.capacityGB}GB${model.memory.type ? ` / ${model.memory.type}` : ''}`],['ストレージ',`${model.storage.capacityGB}GB${model.storage.interface ? ` / ${model.storage.interface}` : ''}`]] },
  { key:'display', icon:'🖥', title:'ディスプレイ', items:[['サイズ',`${model.display.sizeInch}インチ`],['解像度',resolution],['比率',model.display.aspectRatio],['パネル',model.display.panelType],['リフレッシュレート',model.display.refreshRateHz === null || model.display.refreshRateHz === undefined ? null : `${model.display.refreshRateHz}Hz`],['輝度',model.display.brightnessNits === null || model.display.brightnessNits === undefined ? null : `${model.display.brightnessNits} nits`],['タッチ',yesNo(model.display.touch)],['ペン',yesNo(model.display.pen)]] },
  { key:'connectivity', icon:'🔌', title:'接続・ポート', items:[['Wi-Fi',model.connectivity.wifi.standard],['Bluetooth',model.connectivity.bluetooth],['WWAN',model.connectivity.wwan.type],['USB-C',model.ports.usbC ? `${model.ports.usbC.count}基 / ${model.ports.usbC.spec}` : null],['USB-A',model.ports.usbA === null || model.ports.usbA === undefined ? null : `${model.ports.usbA}基`],['HDMI',model.ports.hdmi],['カードリーダー',model.ports.cardReader],['オーディオジャック',yesNo(model.ports.audioJack)]] },
  { key:'portability', icon:'⚖', title:'携帯性', items:[['重量',`${model.physical.weightG}g`],['寸法',`${model.physical.dimensions.width} × ${model.physical.dimensions.depth} × ${model.physical.dimensions.thicknessMax}mm`],['設置面積',`${model.footprintCm2.toFixed(0)}cm²`],['体積',`${model.volumeCm3.toFixed(0)}cm³`],['筐体素材',model.physical.chassisMaterial],['携帯性スコア',`${model.portabilityScore}/100`]] },
  { key:'battery', icon:'🔋', title:'バッテリー', items:[['容量',`${model.battery.capacityWh}Wh`],['バッテリー密度',`${model.batteryDensity.toFixed(3)}Wh/g`],['充電器',`${model.battery.charger.watt}W / USB PD ${model.battery.charger.usbPd ? '対応' : '—'}`],['バッテリースコア',`${model.batteryScore.toFixed(0)}/100`]] },
  { key:'io', icon:'📷', title:'入出力・認証', items:[['Webカメラ',model.io?.webcam?.resolution],['IRカメラ',yesNo(model.io?.webcam?.ir)],['プライバシーシャッター',yesNo(model.io?.webcam?.privacyShutter)],['顔認証',yesNo(model.io?.windowsHello?.face)],['指紋認証',yesNo(model.io?.windowsHello?.fingerprint)],['キーボード配列',model.io?.keyboard?.layout],['バックライト',yesNo(model.io?.keyboard?.backlight)]] },
];
const badges = [
  model.copilotPlusPc && ['performance','Copilot+ PC'], model.connectivity.wwan.type !== 'none' && ['connectivity',model.connectivity.wwan.type], model.ports.thunderbolt && ['connectivity','Thunderbolt'], model.display.panelType === 'OLED' && ['display','OLED'], model.io?.windowsHello?.face && ['io','顔認証']
].filter(Boolean) as [string, string][];
const scores = [['性能',model.performanceScore100,'performance'],['携帯性',model.portabilityScore,'portability'],['バッテリー',model.batteryScore,'battery'],['通信',model.connectivityScore,'connectivity'],['コスパ',model.valueScore,'io']] as const;
const jsonLd={ '@context':'https://schema.org', '@type':'Product', name:model.modelName, brand:{'@type':'Brand',name:model.maker}, ...(model.imageUrl ? {image:model.imageUrl} : {}), offers:{'@type':'Offer',price:model.pricing.priceJpy,priceCurrency:'JPY',availability:'https://schema.org/InStock'}, url:model.productUrl };
const safeJsonLd = JSON.stringify(jsonLd).replaceAll('<', '\\u003c').replaceAll('>', '\\u003e').replaceAll('&', '\\u0026');
---
<SiteShell title={`${model.modelName} | Mobiles`}>
  <script is:inline type="application/ld+json" set:html={safeJsonLd} />
  <a class="text-sm text-brand underline" href={withBase('')}>← 一覧へ</a>
  <section class="surface mt-4 overflow-hidden p-5 md:p-7">
    <div class="grid items-center gap-7 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <div class="relative overflow-hidden rounded-xl"><div class="product-placeholder" aria-hidden="true">💻</div>{model.imageUrl && <img class="product-image absolute inset-0 h-full w-full" src={model.imageUrl} alt={`${model.modelName} の製品画像`} loading="lazy" decoding="async" referrerpolicy="no-referrer" onerror="this.style.display='none'" />}</div>
      <div><p class="text-sm font-medium text-slate-500 dark:text-slate-400">{model.maker} / {model.series}</p><h1 class="mt-1 text-3xl font-bold tracking-tight">{model.modelName}</h1><p class="mt-3 text-2xl font-semibold">¥{model.pricing.priceJpy.toLocaleString()} <span class="text-sm font-normal text-slate-500">({model.pricing.priceType === 'msrp' ? '税込参考価格' : '実売価格'})</span></p><div class="mt-4 flex flex-wrap gap-2">{badges.map(([category,label])=><span class={`category-${category} inline-flex items-center gap-1 rounded-full border border-slate-200 px-2 py-1 text-xs text-slate-700 dark:border-slate-700 dark:text-slate-200`}><i class="badge-dot h-1.5 w-1.5 rounded-full"></i>{label}</span>)}</div><div class="mt-5"><ModelActions id={model.id} client:load /></div></div>
    </div>
  </section>
  <section class="mt-6"><h2 class="text-lg font-bold">主要スコア</h2><div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">{scores.map(([label,value,category])=><div class={`category-${category} surface p-4`}><div class="flex items-baseline justify-between"><span class="text-sm text-slate-500 dark:text-slate-400">{label}</span><strong class="text-xl">{value === null ? '—' : `${Math.round(value)}`}</strong></div><div class="mt-3 h-1.5 rounded-full bg-slate-100 dark:bg-slate-800"><div class="h-full rounded-full" style={`width: ${value === null ? 0 : value}%; background: var(--category-color)`}></div></div><span class="mt-1 block text-right text-xs text-slate-500">/ 100</span></div>)}</div></section>
  <section class="mt-7"><h2 class="text-lg font-bold">スペック詳細</h2><div class="mt-3 grid gap-4 md:grid-cols-2">{groups.map(group=><section class={`category-${group.key} category-panel surface p-5`}><h3 class="category-title flex items-center gap-2 font-bold"><span>{group.icon}</span>{group.title}</h3><dl class="mt-3 divide-y divide-slate-100 text-sm dark:divide-slate-800">{group.items.map(([label,value])=><div class="grid grid-cols-[minmax(7rem,.9fr)_minmax(0,1.1fr)] gap-4 py-2"><dt class="text-slate-500 dark:text-slate-400">{label}</dt><dd>{dash(value)}</dd></div>)}</dl>{group.key === 'battery' && <div class="mt-4 border-t border-slate-100 pt-3 text-sm dark:border-slate-800"><p class="text-slate-500 dark:text-slate-400">公称駆動時間</p><ul class="mt-1 space-y-1">{model.battery.ratedLife.length ? model.battery.ratedLife.map(life=><li>{life.hours}時間 <span class="text-slate-500">({life.method})</span></li>) : <li>—</li>}</ul></div>}</section>)}</div></section>
  <section class="surface mt-7 p-5"><h2 class="text-lg font-bold">構成・出典</h2><p class="mt-2 text-sm">更新日: {model.lastUpdated}</p>{model.pricing.variants.length > 0 && <div class="mt-4 overflow-x-auto"><table class="min-w-full text-sm"><thead><tr class="border-b text-left"><th class="p-2">構成</th><th class="p-2">メモリ</th><th class="p-2">ストレージ</th><th class="p-2">価格</th></tr></thead><tbody>{model.pricing.variants.map(variant=><tr class="border-b border-slate-100 dark:border-slate-800"><td class="p-2">{variant.label}</td><td class="p-2">{variant.memoryGB}GB</td><td class="p-2">{variant.storageGB}GB</td><td class="p-2">¥{variant.priceJpy.toLocaleString()}</td></tr>)}</tbody></table></div>}<ul class="mt-4 space-y-2">{model.sources.map(source=><li class="text-sm"><span class="mr-2 rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-300">{source.field ?? '全般'}</span><a class="text-brand underline" href={source.url} target="_blank" rel="noreferrer">{source.publisher}</a> <span class="text-slate-500">取得日 {source.retrievedAt}</span></li>)}</ul></section>
</SiteShell>
