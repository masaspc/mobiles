---
import { getCollection } from 'astro:content'; import SiteShell from '../../components/SiteShell.astro'; import ModelActions from '../../components/ModelActions'; import { deriveModel } from '../../data/schema';
export async function getStaticPaths() { const all=await getCollection('models'); return all.map(entry=>({params:{id:entry.data.id},props:{model:deriveModel(entry.data)}})); }
const { model } = Astro.props;
const sections = [{title:'基本情報', items:[['OS',model.os.family],['フォーム',model.formFactor],['発売日',model.releaseDate]]},{title:'性能と携帯性',items:[['CPU',`${model.cpu.vendor} ${model.cpu.model}`],['メモリ',`${model.memory.capacityGB}GB ${model.memory.type??''}`],['ストレージ',`${model.storage.capacityGB}GB`],['重量',`${model.physical.weightG}g`],['携帯性スコア',`${model.portabilityScore}点`]]},{title:'通信・電源',items:[['Wi-Fi',model.connectivity.wifi.standard],['WWAN',model.connectivity.wwan?.type],['バッテリー',`${model.battery.capacityWh}Wh`],['USB PD',model.ports.usbPd?'対応':'—']]}];
const jsonLd={ '@context':'https://schema.org', '@type':'Product', name:model.modelName, brand:{'@type':'Brand',name:model.maker}, offers:{'@type':'Offer',price:model.pricing.priceJpy,priceCurrency:'JPY',availability:'https://schema.org/InStock'}, url:model.productUrl };
---
<SiteShell title={`${model.modelName} | Mobiles`}><script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /><a class="text-sm text-brand underline" href={import.meta.env.BASE_URL}>← 一覧へ</a><section class="mt-4 flex flex-wrap items-start justify-between gap-4"><div><p class="text-sm text-brand">{model.maker} / {model.series}</p><h1 class="text-3xl font-bold">{model.modelName}</h1><p class="mt-2 text-slate-600 dark:text-slate-300">更新日: {model.lastUpdated}</p></div><ModelActions id={model.id} client:load /></section><div class="mt-7 grid gap-5 md:grid-cols-3">{sections.map(section=><section class="surface p-5"><h2 class="mb-3 text-lg font-bold">{section.title}</h2><dl class="space-y-2 text-sm">{section.items.map(([k,v])=><div class="flex justify-between gap-4 border-b border-slate-100 pb-2 dark:border-slate-800"><dt class="text-slate-500">{k}</dt><dd class="text-right font-medium">{v??'—'}</dd></div>)}</dl></section>)}</div><section class="surface mt-5 p-5"><h2 class="text-lg font-bold">構成・出典</h2><p class="mt-2">基準価格: ¥{model.pricing.priceJpy.toLocaleString()}（{model.pricing.priceType}）</p><ul class="mt-4 list-disc pl-5">{model.sources.map(source=><li><a class="text-brand underline" href={source.url} target="_blank" rel="noreferrer">{source.publisher}</a> <span class="text-sm text-slate-500">取得日 {source.retrievedAt}</span></li>)}</ul></section></SiteShell>
