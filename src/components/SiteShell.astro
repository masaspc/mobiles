---
import '../styles/global.css';
import { withBase } from '../lib/url';
const { title = 'Mobiles | モバイルPC比較' } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="モバイルPCを重量、性能、通信、バッテリーで比較するデータベース" />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.toggle('dark', localStorage.getItem('mobiles-theme') === 'dark' || (!localStorage.getItem('mobiles-theme') && matchMedia('(prefers-color-scheme: dark)').matches));</script>
  </head>
  <body>
    <header class="border-b border-slate-200 bg-white/85 backdrop-blur dark:border-slate-800 dark:bg-slate-950/85">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <a href={withBase('')} class="font-bold text-brand dark:text-cyan-300">Mobiles <span class="font-normal text-slate-500">比較DB</span></a>
        <div class="flex gap-4 text-sm"><a href={withBase('compare/')}>比較</a><a href={withBase('charts/')}>チャート</a><a href={withBase('about/')}>データについて</a></div>
      </nav>
    </header>
    <main class="mx-auto max-w-7xl px-4 py-7"><slot /></main>
  </body>
</html>
